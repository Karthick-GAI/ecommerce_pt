# ─────────────────────────────────────────────────────────────────────────────
# Root .env.example — copy to .env and fill in your values
# All AI-enabled services read this file via python-dotenv.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by: product_catalogue, checkout_service, recommendation_engine,
#          inventory_service, order_management, session_service,
#          payment_shipping_service, guardrails_service, multi_agent_system,
#          shopping_assistant, tool_calling_agent
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Used by: product_catalogue, shopping_assistant, guardrails_service,
#          multi_agent_system, tool_calling_agent
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Deployment names (match what you created in Azure OpenAI Studio)
AZURE_OPENAI_GPT54_MINI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_EMBEDDING_SMALL=text-embedding-3-small

# ── JWT Auth (user_management only — uses SQLite, not PostgreSQL) ─────────────
JWT_SECRET=change-this-to-a-random-256-bit-secret-before-any-real-use

# ── Razorpay (payment_shipping_service) ───────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Shiprocket (payment_shipping_service) ─────────────────────────────────────
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=your_shiprocket_password
