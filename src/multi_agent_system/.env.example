# PostgreSQL — shared with all other services
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgre_catalogue

# Azure OpenAI — same credentials used across the platform
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_GPT54_MINI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_EMBEDDING_SMALL=text-embedding-3-small
